# ───────────────────────────────────────────
#  Discord Bot
# ───────────────────────────────────────────

# Your Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here


# ───────────────────────────────────────────
#  Aternos Account
# ───────────────────────────────────────────

# Your Aternos login credentials
ATERNOS_USERNAME=your_aternos_username
ATERNOS_PASSWORD=your_aternos_password

# (Optional) Part of your server domain to match — e.g. "myserver"
# Leave blank to use the first server on the account
ATERNOS_SERVER=


# ───────────────────────────────────────────
#  Bot Behaviour (Optional)
# ───────────────────────────────────────────

# Role name required to run /start and /stop (leave blank = everyone can)
ALLOWED_ROLE_NAME=Admin

# Channel ID for automatic 5-minute status updates (leave blank = disabled)
STATUS_CHANNEL_ID=
